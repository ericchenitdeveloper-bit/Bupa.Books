{
  "Urls": "http://localhost:5000",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "bupa-books-dev-secret-key-minimum-32chars!",
    "Issuer": "bupa-books-public-api",
    "Audience": "bupa-books-clients"
  },
  "MockAuth": {
    "Username": "demo",
    "Password": "demo123"
  },
  "PrivateApi": {
    "BaseUrl": "http://localhost:5001/",
    "ApiKey": "bupa-internal-dev-api-key-change-in-production",
    "Resilience": {
      "TimeoutSeconds": 10,
      "Retry": {
        "Count": 3,
        "DelaySeconds": 1
      },
      "CircuitBreaker": {
        "FailureThreshold": 0.5,
        "MinimumThroughput": 10,
        "SamplingDurationSeconds": 30,
        "DurationOfBreakSeconds": 30
      }
    }
  }
}
