{
  "Urls": "http://localhost:5001",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "BooksApi": {
    "BaseUrl": "https://digitalcodingtest.bupa.com.au/",
    "Resilience": {
      "TimeoutSeconds": 10,
      "Retry": {
        "Count": 3,
        "DelaySeconds": 1
      },
      "CircuitBreaker": {
        "FailureThreshold": 0.5,
        "MinimumThroughput": 10,
        "SamplingDurationSeconds": 30,
        "DurationOfBreakSeconds": 30
      }
    }
  },
  "PrivateApi": {
    "ApiKey": "bupa-internal-dev-api-key-change-in-production"
  }
}
